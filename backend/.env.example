# ClaimPilot AI — backend environment variables
# Copy to backend/.env and fill in real values. Never commit .env.

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required. API key for GPT vision, reasoning, fast, and copilot calls.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model slug for coding review, appeal letters, dispute replies, and copilot reasoning turns.
MODEL_REASONING=gpt-4o

# Model slug for Review Copilot factual / glossary questions.
MODEL_FAST=gpt-4o-mini

# Model slug for superbill vision extraction (intake agent).
MODEL_VISION=gpt-4o-mini

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required. Project URL from Supabase Dashboard → Settings → API.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Required. Service role key (server-side only — never expose to the browser).
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxx

# Optional. Direct Postgres connection string for scripts/run_migrations.py only.
SUPABASE_DB_URL=postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── Resend (email) ────────────────────────────────────────────────────────────
# API key for outbound appeal, patient statement, and dispute reply emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender address shown on outbound emails (must be verified in Resend).
ALERT_FROM_EMAIL=onboarding@resend.dev

# Demo recipient for appeals, statements, and dispute replies (your inbox for testing).
ALERT_TO_EMAIL=you@example.com

# Inbound/reply-to address configured in Resend for dispute email threading.
RESEND_INBOUND_ADDRESS=disputes@your-inbound-domain.resend.app

# ── Pipeline thresholds ───────────────────────────────────────────────────────
# Intake HITL gate: header fields below this confidence score route to review (0.0–1.0).
CONFIDENCE_THRESHOLD=0.85

# Scrub HITL gate: ML denial-risk scores at or above this value route to review (0.0–1.0).
DENIAL_RISK_THRESHOLD=0.60

# Reconciliation HITL gate: payment variance above this fraction of expected routes to review.
RECON_VARIANCE_TOLERANCE=0.05

# ── RBAC demo thresholds ──────────────────────────────────────────────────────
# Billers cannot approve claims with total charge above this dollar amount.
BILLER_APPROVAL_MAX_CHARGE=500

# Billers cannot approve claims at or above this denial-risk score (0.0–1.0).
BILLER_APPROVAL_MAX_RISK=0.75

# ── Optional tooling ──────────────────────────────────────────────────────────
# Path to Poppler bin directory for PDF→image conversion in intake (Windows default probed if unset).
POPPLER_PATH=C:\poppler\poppler-24.08.0\Library\bin
